# Copy this to ".env" (same folder as docker-compose.yml) to override defaults.
# docker compose reads ".env" automatically. Everything here is OPTIONAL — the
# stack runs with sensible defaults if you leave it untouched.

# Where the containers find Ollama. Default assumes Ollama runs on the host
# machine (Docker Desktop maps host.docker.internal automatically; on Linux the
# compose file adds the host-gateway mapping for you).
# Comma-separate multiple hosts for round-robin/failover.
OLLAMA_HOSTS=http://host.docker.internal:11434

# Optional: auto-connect the Discord bot on startup. If left blank you can paste
# the token in the Discord page of the UI instead.
DISCORD_BOT_TOKEN=
