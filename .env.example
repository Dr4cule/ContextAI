# ContextAI environment configuration
# -------------------------------------
# Everything below is OPTIONAL - the app ships with working defaults and runs
# without any .env file. Copy this to backend/.env (and/or server/.env) only to
# override defaults.

# --- AI engine: Ollama ---
# Comma-separated list of Ollama servers. Defaults to a single local server
# at http://localhost:11434 so the app runs out of the box. Add more hosts
# for round-robin + failover, e.g. http://localhost:11434,http://gpu-box:11434
OLLAMA_HOSTS=http://localhost:11434

# Model overrides (defaults shown). minimax-m3:cloud handles BOTH text and
# vision, so the vision model defaults to the text model.
OLLAMA_TEXT_MODEL=minimax-m3:cloud
# OLLAMA_VISION_MODEL=minimax-m3:cloud
# Embeddings are only used by the optional RAG server. If no embedding model
# is installed, RAG falls back to a local hash-based vector (set
# OLLAMA_LOCAL_EMBED_FALLBACK=false to require a real model instead).
# OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Per-request timeout in ms (cloud models can be slow). Default 180000.
# OLLAMA_TIMEOUT_MS=180000

# --- Discord (optional) ---
# Without a token, discord_api.js still boots in "disconnected" mode.
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# --- RAG server storage (optional) ---
# If DATABASE_URL is set AND reachable, the RAG server uses PostgreSQL + pgvector.
# Otherwise it falls back to a built-in file-backed vector store (no DB needed).
# DATABASE_URL=postgresql://user:password@localhost:5432/contextai
# RAG_STORE_FILE=./rag_store.json
